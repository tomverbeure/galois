    cell (NAND2) {
        area : 4;
        pin(A) {
            direction : input;
        }
        pin(B) {
            direction : input;
        }
        pin(Y) {
            direction: output;
            function : "(A * B)'";
            timing() {
                related_pin : "A";
                timing_sense : negative_unate;
                cell_rise() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
                cell_fall() {
                    index_1("1");
                    index_2("1");
