                }
                fall_transition() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
            }
        }
    }

    cell (DFF) {
        area : 8;
        pin(D) {
            direction : input;
        }	
        pin(CK) {
            direction : input;
            clock : true;
        }
        ff("Q") {
            clocked_on : "CK";
            next_state : "D";
        }
        pin(Q) {
            direction : output;
            function: "Q";
        }
    }
}
