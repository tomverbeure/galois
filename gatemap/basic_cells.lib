    }

    cell (XOR2) {
        area : 6;
        pin(A) {
            direction : input;
        }
        pin(B) {
            direction : input;
        }
        pin(Y) {
            direction: output;
            function : "(A ^ B)";
            timing() {
                related_pin : "A";
                timing_sense : non_unate;
                cell_rise() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
                cell_fall() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
                rise_transition() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
                fall_transition() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
            }
            timing() {
                related_pin : "B";
                timing_sense : non_unate;
                cell_rise() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
                cell_fall() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
