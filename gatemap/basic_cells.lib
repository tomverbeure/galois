                    index_1("1");
                    index_2("1");
                    values("1");
                }
            }
            timing() {
                related_pin : "B";
                timing_sense : negative_unate;
                cell_rise() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
                cell_fall() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
