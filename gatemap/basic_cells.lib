library(basic_cells){

    cell (INV) {
        area : 1;
        pin(A) {
            direction : input;
        }
    
        pin(Y) {
            direction : output;
            function : "A'";
            timing() {
                related_pin : "A";
                timing_sense : negative_unate;
                cell_rise() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
                cell_fall() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
                rise_transition() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
                fall_transition() {
                    index_1("1");
                    index_2("1");
                    values("1");
                }
            }
        }
  }
  
